<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="apex_world">

    <!-- Gazebo Harmonic system plugins -->
    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-imu-system"
            name="gz::sim::systems::Imu"/>
    <plugin filename="gz-sim-contact-system"
            name="gz::sim::systems::Contact"/>

    <!-- 조명 -->
    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
    </light>

    <!-- 바닥 (마찰 높임 — 바퀴 그립 확보) -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="col">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
          <surface><friction><ode><mu>5.0</mu><mu2>5.0</mu2></ode></friction></surface>
        </collision>
        <visual name="vis">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
          <material><ambient>0.8 0.8 0.8 1</ambient><diffuse>0.8 0.8 0.8 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- 물리 설정 -->
    <physics type="ode">
      <real_time_update_rate>250.0</real_time_update_rate>
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1</real_time_factor>
    </physics>

    <!--
      단순화 레이아웃 (6×6m):

          -3          0          +3
      +3  +──────────────────────+
          │                      │
          │   [table]            │
       0  │      ● robot         │
          │            [can]     │
      -3  +──────────────────────+

      장애물 없음 — 로봇이 자유롭게 탐색
    -->

    <!-- ── 외벽 (6×6m 방) ──────────────────────────────── -->
    <model name="wall_north">
      <static>true</static>
      <pose>0 3 0.5 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>6 0.1 1</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>6 0.1 1</size></box></geometry>
          <material><ambient>0.6 0.6 0.6 1</ambient></material></visual>
      </link>
    </model>

    <model name="wall_south">
      <static>true</static>
      <pose>0 -3 0.5 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>6 0.1 1</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>6 0.1 1</size></box></geometry>
          <material><ambient>0.6 0.6 0.6 1</ambient></material></visual>
      </link>
    </model>

    <model name="wall_east">
      <static>true</static>
      <pose>3 0 0.5 0 0 1.5708</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>6 0.1 1</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>6 0.1 1</size></box></geometry>
          <material><ambient>0.6 0.6 0.6 1</ambient></material></visual>
      </link>
    </model>

    <model name="wall_west">
      <static>true</static>
      <pose>-3 0 0.5 0 0 1.5708</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>6 0.1 1</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>6 0.1 1</size></box></geometry>
          <material><ambient>0.6 0.6 0.6 1</ambient></material></visual>
      </link>
    </model>

    <!-- ── APPROACH 탐지 목표: coke_can (빨간 원기둥) ──
         YOLO "bottle" 클래스로 탐지
    ─────────────────────────────────────────────────── -->
    <model name="coke_can_1">
      <static>true</static>
      <pose>1.5 -1.5 0.06 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><cylinder><radius>0.033</radius><length>0.12</length></cylinder></geometry></collision>
        <visual name="vis"><geometry><cylinder><radius>0.033</radius><length>0.12</length></cylinder></geometry>
          <material><ambient>0.8 0.1 0.1 1</ambient><diffuse>0.8 0.1 0.1 1</diffuse></material></visual>
      </link>
    </model>

    <!-- ── AVOID 목표: cafe_table (갈색 박스) ────────────
         YOLO "dining table" 클래스로 탐지 시 장애물 주입
    ─────────────────────────────────────────────────── -->
    <model name="cafe_table_1">
      <static>true</static>
      <pose>-1.5 1.5 0.4 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.9 0.9 0.8</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.9 0.9 0.8</size></box></geometry>
          <material><ambient>0.5 0.35 0.2 1</ambient><diffuse>0.5 0.35 0.2 1</diffuse></material></visual>
      </link>
    </model>

    <!-- ── TurtleBot3 Waffle Pi (Gazebo Harmonic 네이티브 플러그인) ── -->
    <model name="turtlebot3_waffle_pi">
      <pose>0 0 0.01 0 0 0</pose>

      <!-- base_footprint: 모델 원점 -->
      <link name="base_footprint"/>

      <!-- base_joint: base_footprint → base_link (+10mm) -->
      <joint name="base_joint" type="fixed">
        <parent>base_footprint</parent>
        <child>base_link</child>
        <pose>0 0 0.010 0 0 0</pose>
      </joint>

      <!-- base_link: 차체 -->
      <link name="base_link">
        <pose>0 0 0.010 0 0 0</pose>
        <inertial>
          <mass>1.3729096</mass>
          <inertia>
            <ixx>8.7002718e-03</ixx><ixy>-4.7576583e-05</ixy><ixz>1.1160499e-04</ixz>
            <iyy>8.6195418e-03</iyy><iyz>-3.5422299e-06</iyz><izz>1.3938951e-02</izz>
          </inertia>
        </inertial>
        <collision name="col">
          <pose>-0.064 0 0.048 0 0 0</pose>
          <geometry><box><size>0.266 0.266 0.089</size></box></geometry>
        </collision>
        <visual name="vis">
          <pose>-0.064 0 0.048 0 0 0</pose>
          <geometry><box><size>0.266 0.266 0.089</size></box></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
      </link>

      <!-- 왼쪽 바퀴 -->
      <joint name="wheel_left_joint" type="revolute">
        <parent>base_link</parent>
        <child>wheel_left_link</child>
        <axis>
          <xyz>0 1 0</xyz>
          <limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit>
          <dynamics><damping>0.001</damping><friction>0.001</friction></dynamics>
        </axis>
      </joint>
      <link name="wheel_left_link">
        <pose>0 0.144 0.033 -1.5707963 0 0</pose>
        <inertial>
          <mass>0.1</mass>
          <inertia><ixx>3.17e-05</ixx><ixy>0</ixy><ixz>0</ixz><iyy>3.17e-05</iyy><iyz>0</iyz><izz>5.145e-05</izz></inertia>
        </inertial>
        <collision name="col">
          <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
          <surface>
            <friction><ode><mu>5.0</mu><mu2>5.0</mu2></ode></friction>
            <contact><ode><kp>1e8</kp><kd>1</kd><max_vel>0.01</max_vel><min_depth>0.001</min_depth></ode></contact>
          </surface>
        </collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient></material>
        </visual>
      </link>

      <!-- 오른쪽 바퀴 -->
      <joint name="wheel_right_joint" type="revolute">
        <parent>base_link</parent>
        <child>wheel_right_link</child>
        <axis>
          <xyz>0 1 0</xyz>
          <limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit>
          <dynamics><damping>0.001</damping><friction>0.001</friction></dynamics>
        </axis>
      </joint>
      <link name="wheel_right_link">
        <pose>0 -0.144 0.033 -1.5707963 0 0</pose>
        <inertial>
          <mass>0.1</mass>
          <inertia><ixx>3.17e-05</ixx><ixy>0</ixy><ixz>0</ixz><iyy>3.17e-05</iyy><iyz>0</iyz><izz>5.145e-05</izz></inertia>
        </inertial>
        <collision name="col">
          <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
          <surface>
            <friction><ode><mu>5.0</mu><mu2>5.0</mu2></ode></friction>
            <contact><ode><kp>1e8</kp><kd>1</kd><max_vel>0.01</max_vel><min_depth>0.001</min_depth></ode></contact>
          </surface>
        </collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient></material>
        </visual>
      </link>

      <!-- 앞 캐스터 -->
      <joint name="caster_front_joint" type="fixed">
        <parent>base_link</parent>
        <child>caster_front_link</child>
      </joint>
      <link name="caster_front_link">
        <pose>0.073 0 0.005 0 0 0</pose>
        <inertial><mass>0.01</mass><inertia><ixx>1e-06</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1e-06</iyy><iyz>0</iyz><izz>1e-06</izz></inertia></inertial>
        <collision name="col"><geometry><sphere><radius>0.005</radius></sphere></geometry><surface><friction><ode><mu>0</mu><mu2>0</mu2></ode></friction></surface></collision>
        <visual name="vis"><geometry><sphere><radius>0.005</radius></sphere></geometry><material><ambient>0.8 0.8 0.8 1</ambient></material></visual>
      </link>

      <!-- 뒤 캐스터 -->
      <joint name="caster_back_joint" type="fixed">
        <parent>base_link</parent>
        <child>caster_back_link</child>
      </joint>
      <link name="caster_back_link">
        <pose>-0.177 0 0.005 0 0 0</pose>
        <inertial><mass>0.01</mass><inertia><ixx>1e-06</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1e-06</iyy><iyz>0</iyz><izz>1e-06</izz></inertia></inertial>
        <collision name="col"><geometry><sphere><radius>0.005</radius></sphere></geometry><surface><friction><ode><mu>0</mu><mu2>0</mu2></ode></friction></surface></collision>
        <visual name="vis"><geometry><sphere><radius>0.005</radius></sphere></geometry><material><ambient>0.8 0.8 0.8 1</ambient></material></visual>
      </link>

      <!-- LiDAR -->
      <joint name="scan_joint" type="fixed">
        <parent>base_link</parent>
        <child>base_scan</child>
      </joint>
      <link name="base_scan">
        <pose>-0.064 0 0.131 0 0 0</pose>
        <sensor name="lidar" type="gpu_lidar">
          <topic>/scan</topic>
          <gz_frame_id>base_scan</gz_frame_id>
          <update_rate>5</update_rate>
          <lidar>
            <scan>
              <horizontal>
                <samples>360</samples>
                <resolution>1</resolution>
                <min_angle>0</min_angle>
                <max_angle>6.28318530718</max_angle>
              </horizontal>
            </scan>
            <range><min>0.120</min><max>3.5</max><resolution>0.015</resolution></range>
            <noise><type>gaussian</type><mean>0</mean><stddev>0.01</stddev></noise>
          </lidar>
          <always_on>true</always_on>
          <visualize>false</visualize>
        </sensor>
      </link>

      <!-- 카메라 -->
      <joint name="camera_joint" type="fixed">
        <parent>base_link</parent>
        <child>camera_rgb_frame</child>
      </joint>
      <link name="camera_rgb_frame">
        <pose>0.073 -0.011 0.094 0 0 0</pose>
        <sensor name="camera" type="camera">
          <topic>/camera/image_raw</topic>
          <gz_frame_id>camera_rgb_optical_frame</gz_frame_id>
          <update_rate>10</update_rate>
          <camera>
            <horizontal_fov>1.3962634015954636</horizontal_fov>
            <image><width>640</width><height>480</height><format>RGB_INT8</format></image>
            <clip><near>0.1</near><far>100</far></clip>
            <noise><type>gaussian</type><mean>0</mean><stddev>0.007</stddev></noise>
          </camera>
          <always_on>true</always_on>
          <visualize>false</visualize>
        </sensor>
      </link>

      <!-- IMU -->
      <joint name="imu_joint" type="fixed">
        <parent>base_link</parent>
        <child>imu_link</child>
      </joint>
      <link name="imu_link">
        <pose>0 0 0.078 0 0 0</pose>
        <sensor name="imu" type="imu">
          <topic>/imu</topic>
          <update_rate>200</update_rate>
          <always_on>true</always_on>
        </sensor>
      </link>

      <!-- Gazebo Harmonic: DiffDrive (odom + TF 자동 publish) -->
      <plugin filename="gz-sim8-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <left_joint>wheel_left_joint</left_joint>
        <right_joint>wheel_right_joint</right_joint>
        <wheel_separation>0.287</wheel_separation>
        <wheel_radius>0.033</wheel_radius>
        <odom_publish_frequency>30</odom_publish_frequency>
        <topic>/cmd_vel</topic>
        <odom_topic>/odom</odom_topic>
        <tf_topic>/tf</tf_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>base_footprint</child_frame_id>
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
      </plugin>

      <!-- Gazebo Harmonic: 바퀴 조인트 상태 publish -->
      <plugin filename="gz-sim8-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
        <topic>/joint_states</topic>
        <joint_name>wheel_left_joint</joint_name>
        <joint_name>wheel_right_joint</joint_name>
      </plugin>
    </model>

  </world>
</sdf>
